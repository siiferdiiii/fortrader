# =============================================
# ForTrader — Environment Variables
# Salin file ini ke .env dan isi nilainya
# JANGAN commit .env ke Git!
# =============================================

# ─── Supabase (WAJIB) ─────────────────────
# Dapatkan dari: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── App ──────────────────────────────────
APP_URL=https://your-app.vercel.app

# ─── iPaymu Payment Gateway ───────────────
IPAYMU_VA=your-virtual-account
IPAYMU_API_KEY=your-ipaymu-api-key
IPAYMU_URL=https://my.ipaymu.com/api/v2
